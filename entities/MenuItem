{
  "name": "MenuItem",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the menu item"
    },
    "price": {
      "type": "number",
      "description": "Price in TWD"
    },
    "category": {
      "type": "string",
      "enum": [
        "\u8c46\u82b1\u7cfb\u5217",
        "\u51b0\u54c1\u7cfb\u5217",
        "\u4ed9\u8349\u7cfb\u5217",
        "\u9ede\u5fc3\u7cfb\u5217"
