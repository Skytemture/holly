{
  "name": "Order",
  "type": "object",
  "properties": {
    "table_no": {
      "type": "number",
      "description": "Table number (0 = takeout)"
    },
    "order_number": {
      "type": "number",
      "description": "3-digit numeric pickup number (e.g. 042)"
    },
    "items": {
      "type": "array",
      "description": "Ordered items, each with its own addons",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          },
          "note": {
            "type": "string"
          },
          "addons": {
            "type": "array",
            "description": "Addons specific to this item",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "price": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "addons": {
      "type": "array",
      "description": "Legacy flat addons (kept for backward compat)",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          }
        }
      }
    },
    "total": {
      "type": "number",
      "description": "Order total in TWD"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "preparing",
        "ready",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "note": {
      "type": "string",
      "description": "Special instructions"
    }
  },
  "required": [
    "table_no",
    "items",
    "total"
  ]
}